# =============================================================================
# AI Provider Keys (required for OCR cleaning)
# =============================================================================
OPENAI_API_KEY=sk-proj-your-key-here

# Anthropic API Configuration (optional, needed if --provider anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# CourseScribe Automation — Course Platform Credentials
# =============================================================================
# These are used for automatic login when the browser session expires.
# If omitted, the tool will pause for manual login instead.

# The login page URL (where the login form is)
COURSESCRIBE_LOGIN_URL=https://example.com/login

# The course starting URL (where to begin capture after login)
COURSESCRIBE_START_URL=https://example.com/course

# Login credentials (only used as fallback when session expires)
COURSESCRIBE_USERNAME=your_username
COURSESCRIBE_PASSWORD=your_password

# Persistent browser profile directory (default: ~/.coursescribe/browser_profile)
# COURSESCRIBE_BROWSER_PROFILE=~/.coursescribe/browser_profile

# =============================================================================
# Optional: Uncomment to customize
# =============================================================================
# OCR_LANGUAGE=eng
# OCR_CONFIG=--oem 3 --psm 6
# LOG_LEVEL=INFO
